# Runtime environment template for training-module.
# Copy to .env and edit values for your environment.

# ---------- Runtime / Device ----------
# Controls visible GPUs for PyTorch/CUDA workers and subprocesses.
CUDA_VISIBLE_DEVICES=0

# ---------- AWS / S3 / Ceph ----------
# Endpoint for S3-compatible storage (Ceph/MinIO/etc.).
S3_ENDPOINT_URL=https://s3.example.internal

# Credentials used by boto3 if not provided by IAM/instance profile.
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
# Optional session token for temporary credentials.
AWS_SESSION_TOKEN=

# Region fallback for AWS SDK resolution.
AWS_REGION=us-east-1
AWS_DEFAULT_REGION=us-east-1

# SSL verification:
# - true/false for default CA behavior.
# - or path to a CA bundle file for private PKI.
S3_VERIFY_SSL=true
AWS_CA_BUNDLE=
S3_CA_CERT=

# ---------- S3 Client Tuning ----------
# Connection/read timeout (seconds).
S3_CONNECT_TIMEOUT=10
S3_READ_TIMEOUT=60

# Retry policy.
# mode: legacy | standard | adaptive
S3_RETRY_MODE=standard
S3_RETRY_MAX_ATTEMPTS=10

# ---------- Optional Dataset/Runtime knobs ----------
# Example app-level toggles consumed by your own configs/scripts.
TRAIN_DATA_ROOT=
VAL_DATA_ROOT=
RUN_NAME=
